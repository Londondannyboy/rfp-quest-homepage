# Environment Variables for RFP.quest Agent

# OpenAI API (optional - kept as fallback)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API (REQUIRED - primary model provider)
# Get your key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model configuration
# Supported values:
#   - claude-opus-4-6 (Anthropic - RECOMMENDED for best visualization)
#   - claude-3-5-sonnet-20241022 (Anthropic - good alternative)
#   - gpt-4o-2024-11-20 (OpenAI - fallback, weaker for visualizations)
LLM_MODEL=claude-opus-4-6
LLM_PROVIDER=anthropic

# Notes:
# - Claude Opus 4.6 is the February 2026 flagship model
# - It provides superior visualization generation
# - GPT-4o models may produce broken or incomplete visualizations
# - Always prefer Anthropic models for this application